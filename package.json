{
  "name": "finance-automation-app",
  "version": "1.0.0",
  "description": "Document-based finance automation app with OCR and transaction processing",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/document-processor.ts",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "seed:verify": "ts-node -r tsconfig-paths/register prisma/verify-seed.ts",
    "db:seed": "npm run seed",
    "db:reset": "prisma db push --force-reset && npm run seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "aws-sdk": "^2.1500.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.0.3",
    "prisma": "^6.19.2",
    "redis": "^4.6.11",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bull": "^4.10.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/multer": "^1.4.8",
    "@types/node": "^20.8.0",
    "@types/uuid": "^9.0.6",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "keywords": [
    "finance",
    "automation",
    "ocr",
    "document-processing",
    "bank-statements",
    "typescript"
  ]
}
